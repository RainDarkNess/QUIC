<Page
    x:Class="MyApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MyApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>

<StackPanel Spacing="8">
<TextBox x:Name="TextBox1" Text="Hello, its QUIC`s server. To start server click on button" Width="1900" Height="100" Margin="20,20,20,20" FontSize="14"/>
<TextBox x:Name="TextBoxStatus" Text="Here is status of server" Width="1900" Height="100" Margin="20,30,20,20" FontSize="14"/>
<TextBox x:Name="TextBoxConnect" Text="Here is IP of client" Width="1900" Height="100" Margin="20,40,20,20" FontSize="14"/>
<TextBox x:Name="FileReaderText" Text="Here text of client" Width="1900" Height="100" Margin="20,50,20,20" FontSize="14"/>

    <Button Content="Elevation 0"
            x:Name="Button1"
            Style="{StaticResource MaterialElevatedButtonStyle}"
            Click="Button1_Click"/>
</StackPanel> 
    
    </Grid>
</Page>
